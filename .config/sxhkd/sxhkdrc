#
# wm independent hotkeys
#

# terminal emulator
{ctrl + alt + t, super + Return}
    kitty

# rofi
super + {_,ctrl} + r
    modi={drun,run}; \
    rofi -modi "$modi" -show "$modi" -show-icons -m -4

# make sxhkd reload its configuration files:
super + Escape
    pkill -USR1 -x sxhkd; notify-send.py --replaces-process "sxhkd" "sxhkd reloaded"

# media
XF86Audio{Raise,Lower}Volume
    volume {inc,dec}

XF86AudioMute
    volume {mute}

XF86Audio{Prev,Play,Next}
    playerctl {previous,play-pause,next}

# notifications
super + n
    kill -s USR1 $(pidof deadd-notification-center)

# screenshots
super + shift + s
    scrot --select --freeze '/tmp/%Y-%m-%d_$wx$h.png' -e 'xclip -i $f -t image/png -selection clipboard && rm $f'

#
# bspwm hotkeys
#

# quit/restart bspwm
super + alt + {q,r}
    bspc {quit,wm -r}

# close and kill
super + {_,shift + }w
    bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
    bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
    bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + g
    bspc node -s biggest.window

# rotate the tree counterclockwise/clockwise
super + {q,a}
    bspc node @/ -C {backward, forward}

#
# state/flags
#

# set the window state
super + {t,shift + t,s,f}
    bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
super + ctrl + {m,x,y,z}
    bspc node -g {marked,locked,sticky,private}

#
# focus/swap/resize
#

# focus the node in the given direction
super + {_,shift + }{h, Left, j, Down, k, Up, l, Right}
    bspc node -{f,s} {west,west,south,south,north,north,east,east}

super + equal : {h, Left, j, Down, k, Up, l, Right}
    STEP=20; SELECTION={1,1,2,2,3,3,4,4}; \
    bspc node -z $(echo "left -$STEP 0,bottom 0 $STEP,top 0 -$STEP,right $STEP 0" | cut -d',' -f$SELECTION) || \
    bspc node -z $(echo "right -$STEP 0,top 0 $STEP,bottom 0 -$STEP,left $STEP 0" | cut -d',' -f$SELECTION)

# focus the node for the given path jump
super + {p,b,comma,period}
    bspc node -f @{parent,brother,first,second}

# focus the next/previous window in the current desktop
super + {_,shift + }c
    bspc node -f {next,prev}.local.!hidden.window

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
    bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
    bspc {node,desktop} -f last

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} '^{1-9,10}' --follow
